---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjectBySlug, getProjectSlugs } from '../../lib/sanity';
import { renderPortableText } from '../../lib/portable-text';

export async function getStaticPaths() {
  const slugs = await getProjectSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;

if (!slug) {
  throw new Error('Missing project slug.');
}

const project = await getProjectBySlug(slug);

if (!project) {
  throw new Error(`Project not found for slug: ${slug}`);
}

const formattedDate = project.publishedAt
  ? new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long' }).format(new Date(project.publishedAt))
  : null;
const projectDescription =
  project.summary ?? `Case study for ${project.title}, a project built by Keegan Gaffney.`;

// Render portable text body if available
const bodyHtml = project.body ? renderPortableText(project.body) : null;

// Collect all external links
const links = [
  project.liveUrl && { label: 'Live Site', url: project.liveUrl, icon: 'globe' },
  project.repoUrl && { label: 'Source Code', url: project.repoUrl, icon: 'github' },
  project.figmaUrl && { label: 'Figma', url: project.figmaUrl, icon: 'figma' },
  project.devpostUrl && { label: 'Devpost', url: project.devpostUrl, icon: 'devpost' },
].filter(Boolean) as { label: string; url: string; icon: string }[];

// Meta items for the sidebar
const metaItems = [
  project.role && { label: 'Role', value: project.role },
  formattedDate && { label: 'Date', value: formattedDate },
  project.stack && { label: 'Stack', value: project.stack.join(' · ') },
].filter(Boolean) as { label: string; value: string }[];
---

<BaseLayout
  title={`${project.title} | Keegan Gaffney`}
  description={projectDescription}
  image={project.imageUrl ?? '/IMG_0965-optimized.jpg'}
  type="article"
>
  <article class="project-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb entrance" aria-label="Back to projects">
      <a href="/projects" class="breadcrumb-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Projects
      </a>
    </nav>

    <!-- =============================================
         HERO: Full-width cinematic header
         ============================================= -->
    <header class="hero entrance entrance-d1">
      <div class="hero-eyebrow">
        {formattedDate && <span class="hero-date">{formattedDate}</span>}
        {project.role && (
          <>
            {formattedDate && <span class="eyebrow-sep" aria-hidden="true">/</span>}
            <span class="hero-role">{project.role}</span>
          </>
        )}
      </div>
      <h1 class="hero-title">{project.title}</h1>
      {project.summary && (
        <p class="hero-summary">{project.summary}</p>
      )}

      {project.stack && project.stack.length > 0 && (
        <div class="hero-stack">
          {project.stack.map((tag) => (
            <span class="pill">{tag}</span>
          ))}
        </div>
      )}

      {links.length > 0 && (
        <div class="hero-links">
          {links.map((link) => (
            <a href={link.url} target="_blank" rel="noreferrer" class="btn btn-secondary">
              {link.icon === 'github' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/></svg>
              )}
              {link.icon === 'globe' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              )}
              {link.icon === 'figma' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5z"/><path d="M12 2h3.5a3.5 3.5 0 1 1 0 7H12V2z"/><path d="M12 12.5a3.5 3.5 0 1 1 7 0 3.5 3.5 0 1 1-7 0z"/><path d="M5 19.5A3.5 3.5 0 0 1 8.5 16H12v3.5a3.5 3.5 0 1 1-7 0z"/><path d="M5 12.5A3.5 3.5 0 0 1 8.5 9H12v7H8.5A3.5 3.5 0 0 1 5 12.5z"/></svg>
              )}
              {link.icon === 'devpost' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M6.002 1.61L0 12.004 6.002 22.39h11.996L24 12.004 17.998 1.61H6.002zm1.593 4.084h3.947c3.605 0 6.276 1.695 6.276 6.31 0 4.436-3.21 6.302-6.456 6.302H7.595V5.694zm2.517 2.449v7.714h1.241c2.646 0 3.862-1.55 3.862-3.861.009-2.569-1.096-3.853-3.767-3.853h-1.336z"/></svg>
              )}
              {link.label}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- =============================================
         COVER IMAGE: Edge-to-edge with parallax feel
         ============================================= -->
    {project.imageUrl && (
      <div class="cover entrance entrance-d2">
        <div class="cover-frame">
          <img src={project.imageUrl} alt={project.imageAlt || project.title} />
        </div>
      </div>
    )}

    <!-- =============================================
         BODY: Rich content area with sidebar metadata
         ============================================= -->
    <div class="content-grid">
      <!-- Sidebar with meta -->
      {metaItems.length > 0 && (
        <aside class="sidebar reveal">
          <div class="sidebar-sticky">
            {metaItems.map((item) => (
              <div class="meta-block">
                <dt class="meta-label">{item.label}</dt>
                <dd class="meta-value">{item.value}</dd>
              </div>
            ))}
          </div>
        </aside>
      )}

      <!-- Main content column -->
      <div class="content-main">
        {/* Portable Text body (rich content) */}
        {bodyHtml && (
          <section class="prose reveal" set:html={bodyHtml} />
        )}

        {/* Fallback: plain-text description for older/migrated content */}
        {!bodyHtml && project.description && (
          <section class="prose reveal">
            <p>{project.description}</p>
          </section>
        )}

        {/* ── Gallery ───────────────────────────── */}
        {project.gallery && project.gallery.length > 0 && (
          <section class="gallery reveal">
            <h2 class="gallery-heading">Gallery</h2>
            <div class="gallery-grid">
              {project.gallery.map((img, i) => (
                <figure class="gallery-item">
                  <img src={img.url} alt={img.alt || `${project.title} screenshot ${i + 1}`} loading="lazy" />
                  {img.caption && <figcaption>{img.caption}</figcaption>}
                </figure>
              ))}
            </div>
          </section>
        )}

        {/* ── Challenges & Learnings ──────────── */}
        {(project.challenges?.length || project.learnings?.length) ? (
          <section class="takeaways reveal">
            <div class="takeaways-grid">
              {project.challenges && project.challenges.length > 0 && (
                <div class="takeaway-card">
                  <div class="takeaway-icon takeaway-icon--challenge">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  </div>
                  <h3>Challenges</h3>
                  <ul>
                    {project.challenges.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              )}
              {project.learnings && project.learnings.length > 0 && (
                <div class="takeaway-card">
                  <div class="takeaway-icon takeaway-icon--learning">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  </div>
                  <h3>What I Learned</h3>
                  <ul>
                    {project.learnings.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </section>
        ) : null}
      </div>
    </div>

    <!-- =============================================
         FOOTER CTA
         ============================================= -->
    <footer class="page-cta reveal">
      <div class="cta-inner glass-card">
        <div class="cta-text">
          <h3>Want to see more?</h3>
          <p>Check out my other projects or get in touch.</p>
        </div>
        <div class="cta-actions">
          <a href="/projects" class="btn btn-primary">All projects</a>
          <a href="https://www.linkedin.com/in/keegangaffney/" target="_blank" rel="noreferrer" class="btn btn-secondary">Connect</a>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  /* ========================================
     LAYOUT CONTAINER
     ======================================== */
  .project-page {
    max-width: 960px;
    margin: 0 auto;
  }

  /* ========================================
     BREADCRUMB
     ======================================== */
  .breadcrumb {
    margin-bottom: var(--space-lg);
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-tertiary);
    transition: all var(--duration-fast) var(--ease-out);
    padding: 0.3rem 0;
  }

  .breadcrumb-link:hover {
    color: var(--accent);
    gap: 0.6rem;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    margin-bottom: var(--space-xl);
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-sm);
  }

  .hero-date,
  .hero-role {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-tertiary);
    letter-spacing: 0.01em;
  }

  .eyebrow-sep {
    font-size: 0.75rem;
    color: var(--border-strong);
    user-select: none;
  }

  .hero-title {
    font-size: clamp(2.4rem, 5.5vw, 3.6rem);
    font-weight: 900;
    letter-spacing: -0.045em;
    line-height: 1.04;
    margin-bottom: var(--space-md);
    max-width: 18ch;
  }

  .hero-summary {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 56ch;
    margin-bottom: var(--space-md);
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: var(--space-md);
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ========================================
     COVER IMAGE
     ======================================== */
  .cover {
    margin-bottom: var(--space-2xl);
  }

  .cover-frame {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
    position: relative;
  }

  .cover-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1);
    pointer-events: none;
  }

  .cover-frame img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* ========================================
     CONTENT GRID (sidebar + main)
     ======================================== */
  .content-grid {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  /* ── Sidebar ────────────────────────────── */
  .sidebar {
    padding-top: 0.2rem;
  }

  .sidebar-sticky {
    position: sticky;
    top: calc(60px + var(--space-lg));
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .meta-block {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  .meta-value {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.45;
  }

  /* ── Main content ───────────────────────── */
  .content-main {
    min-width: 0;
  }

  /* ========================================
     PROSE — Portable Text rendered body
     ======================================== */
  .prose {
    margin-bottom: var(--space-2xl);
  }

  .prose :global(p) {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 65ch;
    margin-bottom: 1.25em;
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-top: 2.5em;
    margin-bottom: 0.7em;
    color: var(--text-primary);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 2em;
    margin-bottom: 0.6em;
    color: var(--text-primary);
  }

  .prose :global(h4) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin-top: 1.8em;
    margin-bottom: 0.5em;
    color: var(--text-primary);
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(45,106,79,0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color var(--duration-fast) var(--ease-out);
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .prose :global(code) {
    font-size: 0.88em;
    padding: 0.15em 0.4em;
    background: rgba(0,0,0,0.05);
    border-radius: 4px;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-md);
    margin: 1.5em 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
    color: var(--text-secondary);
  }

  .prose :global(li) {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 0.4em;
  }

  .prose :global(li::marker) {
    color: var(--text-tertiary);
  }

  /* Body figure (inline Portable Text image) */
  .prose :global(.body-figure) {
    margin: 2em 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
  }

  .prose :global(.body-figure img) {
    width: 100%;
    display: block;
  }

  .prose :global(.body-figure figcaption) {
    padding: var(--space-sm) var(--space-md);
    font-size: 0.82rem;
    color: var(--text-tertiary);
    background: var(--bg-glass-strong);
  }

  /* Code blocks inside body */
  .prose :global(.body-code-block) {
    margin: 2em 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: #1e2127;
  }

  .prose :global(.code-filename) {
    padding: 0.5rem var(--space-md);
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    background: rgba(0,0,0,0.2);
    font-family: 'SF Mono', 'Fira Code', monospace;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .prose :global(pre) {
    padding: var(--space-md);
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.65;
    color: #abb2bf;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  /* ========================================
     GALLERY
     ======================================== */
  .gallery {
    margin-bottom: var(--space-2xl);
  }

  .gallery-heading {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-sm);
  }

  .gallery-item {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    transition: all var(--duration-normal) var(--ease-out);
    background: var(--bg-surface);
  }

  .gallery-item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .gallery-item img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .gallery-item figcaption {
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  /* ========================================
     TAKEAWAYS (Challenges / Learnings)
     ======================================== */
  .takeaways {
    margin-bottom: var(--space-2xl);
  }

  .takeaways-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .takeaway-card {
    padding: var(--space-lg);
    background: var(--bg-glass-strong);
    backdrop-filter: blur(12px) saturate(150%);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .takeaway-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-sm);
  }

  .takeaway-icon--challenge {
    background: #fef6e4;
    color: #92750a;
  }

  .takeaway-icon--learning {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .takeaway-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .takeaway-card ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .takeaway-card li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .takeaway-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--border-strong);
  }

  /* ========================================
     FOOTER CTA
     ======================================== */
  .page-cta {
    margin-top: var(--space-xl);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
  }

  .cta-inner:hover {
    transform: none;
  }

  .cta-text h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .cta-text p {
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .cta-actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .sidebar-sticky {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-md) var(--space-xl);
      padding-bottom: var(--space-md);
      border-bottom: 1px solid var(--border);
    }

    .cta-inner {
      flex-direction: column;
      text-align: center;
      padding: var(--space-lg);
    }

    .cta-actions {
      flex-direction: column;
      width: 100%;
    }

    .cta-actions .btn {
      justify-content: center;
    }

    .takeaways-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 1.9rem;
    }

    .hero-summary {
      font-size: 1rem;
    }

    .hero-links {
      flex-direction: column;
